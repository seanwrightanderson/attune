# Attune — Environment Variables
# Copy this file to .env and fill in your values

# LLM
ANTHROPIC_API_KEY=your_anthropic_key_here

# Embeddings
OPENAI_API_KEY=your_openai_key_here

# App
APP_ENV=development
SECRET_KEY=generate_a_random_secret_key_here

# Database (SQLite for local dev — swap for Supabase Postgres URL in production)
DATABASE_URL=sqlite+aiosqlite:///./attune.db

# Vector Store (ChromaDB local — swap for Pinecone in production)
CHROMA_PERSIST_DIR=./chroma_db

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000
